# ─── AQI.me — Flutter Web app + AWS CDK (TypeScript) infra ───

# ===== Flutter / Dart =====
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
.pub-cache/
.pub/
# pubspec.lock IS committed on purpose — this is an app, not a library, and pinning
# transitive versions is what makes scorched-earth rebuilds reproducible.
doc/api/
*.g.dart.lock

# Generated code (freezed / json_serializable / build_runner)
# NOTE: *.g.dart and *.freezed.dart are regenerated by build_runner.
#       Keep them ignored; CI runs `dart run build_runner build`.
*.g.dart
*.freezed.dart

# Flutter/Dart tooling & analysis
.flutter/
.metadata.local

# ===== AWS CDK / Node (infra/) =====
node_modules/
infra/cdk.out/
cdk.out/
*.d.ts                  # compiled from CDK TypeScript
*.js.map
infra/*.js              # compiled CDK output (source is *.ts)
!infra/jest.config.js   # keep hand-written JS config
.cdk.staging/
cdk.context.json        # cached account/zone lookups — machine-specific

# ===== Secrets / env (belt-and-suspenders; app is key-less) =====
.env
.env.*
*.pem
aws-exports.js

# ===== OS / editor =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# ===== Logs / misc =====
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/
